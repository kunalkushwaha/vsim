{
  "name": "vsim-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "A web-native, deterministic 3D animation & short-video framework. Code → video.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "pnpm -r --filter \"./packages/*\" exec rm -rf dist",
    "build": "pnpm run clean && pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node scripts/check-determinism.mjs",
    "render": "tsx packages/cli/src/index.ts render",
    "example:cube": "tsx packages/cli/src/index.ts render examples/01-cube/scene.ts -o out/cube.mp4",
    "example:physics": "tsx packages/cli/src/index.ts render examples/02-physics/scene.ts -o out/physics.mp4",
    "example:beat": "tsx packages/cli/src/index.ts render examples/03-beat-sync/scene.ts -o out/beat.mp4",
    "example:gltf": "tsx packages/cli/src/index.ts render examples/04-gltf/scene.ts -o out/gltf.mp4",
    "example:character": "tsx packages/cli/src/index.ts render examples/05-character/scene.ts -o out/character.mp4",
    "example:fox": "tsx packages/cli/src/index.ts render examples/06-fox/scene.ts -o out/fox.mp4",
    "example:person": "tsx packages/cli/src/index.ts render examples/07-person/scene.ts -o out/person.mp4",
    "example:soccer": "tsx packages/cli/src/index.ts render examples/08-soccer/scene.ts -o out/soccer.mp4",
    "example:manga": "tsx packages/cli/src/index.ts render examples/09-manga/scene.ts -o out/manga.mp4",
    "example:puppy": "tsx packages/cli/src/index.ts render examples/10-puppy/scene.ts -o out/puppy.mp4",
    "example:blender": "tsx packages/cli/src/index.ts render examples/11-blender/scene.ts -o out/blender.mp4",
    "example:makehuman": "tsx packages/cli/src/index.ts render examples/12-makehuman/scene.ts -o out/makehuman.mp4",
    "showreel": "node scripts/build-showreel.mjs",
    "docs:site": "node scripts/build-docs-site.mjs",
    "release:dry": "pnpm build && pnpm -r --filter \"./packages/*\" publish --dry-run --no-git-checks",
    "example:clips": "tsx packages/cli/src/index.ts render examples/13-clips/scene.ts -o out/clips.mp4",
    "example:cast": "tsx packages/cli/src/index.ts render examples/14-cast/scene.ts -o out/cast.mp4",
    "example:clothing": "tsx packages/cli/src/index.ts render examples/15-clothing/scene.ts -o out/clothing.mp4",
    "example:vrm": "tsx packages/cli/src/index.ts render examples/16-vrm/scene.ts -o out/vrm.mp4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "marked": "^18.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "packageManager": "pnpm@9.15.0"
}
